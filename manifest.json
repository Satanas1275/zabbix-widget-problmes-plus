{
	"manifest_version": 2.0,
	"id": "widgetproblemsplus",
	"type": "widget",
	"name": "WidgetProblems Plus",
	"namespace": "WidgetProblemsPlus",
	"version": "1.0",
	"author": "Satanas127",
	"description": "An extension of the Zabbix Problems widget that separates the Problem and Severity into distinct columns.",
	"url": "",
	"widget": {
		"js_class": "CWidgetProblemsPlus",
		"in": {
			"hostids": {
				"type": "_hostids"
			},
			"groupids": {
				"type": "_hostgroupids"
			},
			"override_hostid": {
				"type": "_hostids"
			}
		},
		"out": [
			{
				"type": "_eventid"
			}
		]
	},
	"actions": {
		"widget.widgetproblemsplus.view": {
			"class": "WidgetView"
		}
	},
	"assets": {
		"js": ["class.widget.js"]
	}
}
